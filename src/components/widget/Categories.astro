---
import I18nKey from "../../i18n/i18nKey";
import { i18n, i18nFor } from "../../i18n/translation";
import type { SiteLang } from "../../utils/locale-utils";
import { getCategoryList } from "../../utils/content-utils";
import ButtonLink from "../control/ButtonLink.astro";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
	siteLang?: SiteLang;
}

const {
	class: className,
	style,
	siteLang,
} = Astro.props;

const categories = await getCategoryList(siteLang);

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

const isCollapsed = categories.length >= COLLAPSE_THRESHOLD;
---

<WidgetLayout
	name={
		siteLang
			? i18nFor(siteLang, I18nKey.categories)
			: i18n(I18nKey.categories)
	}
	id="categories"
	isCollapsed={isCollapsed}
	collapsedHeight={COLLAPSED_HEIGHT}
	class={className}
	style={style}
>
    {categories.map((c) =>
        <ButtonLink
            url={c.url}
            badge={String(c.count)}
            label={`View all posts in the ${c.name.trim()} category`}
        >
            {c.name.trim()}
        </ButtonLink>
    )}
</WidgetLayout>